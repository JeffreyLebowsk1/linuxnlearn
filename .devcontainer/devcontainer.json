{
  "name": "LinuxNLearn",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postCreateCommand": "pip install -r requirements.txt && cp -n .env.example .env && python -c \"import secrets, pathlib; p=pathlib.Path('.env'); p.write_text(p.read_text().replace('your_flask_secret_key_here', secrets.token_hex(32)))\"",
  "postStartCommand": "python run.py > /tmp/linuxnlearn.log 2>&1 &",
  "forwardPorts": [5000],
  "portsAttributes": {
    "5000": {
      "label": "LinuxNLearn App",
      "onAutoForward": "openPreview",
      "visibility": "public"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": false
      }
    }
  }
}
