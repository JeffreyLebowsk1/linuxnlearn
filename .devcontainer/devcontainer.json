{
  "name": "LinuxNLearn",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postCreateCommand": "pip install -r requirements.txt && cp -n .env.example .env",
  "forwardPorts": [5000],
  "portsAttributes": {
    "5000": {
      "label": "LinuxNLearn App",
      "onAutoForward": "openPreview",
      "visibility": "public"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": false
      }
    }
  }
}
