# Copy this file to .env and fill in your values.
# At least one AI provider key is required.

# ── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=your_flask_secret_key_here
DEBUG=false
PORT=5000

# ── AI providers ─────────────────────────────────────────────────────────────
# Set the default provider: openai | gemini | perplexity
AI_PROVIDER=perplexity

OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ── ngrok (optional) ─────────────────────────────────────────────────────────
# Set your authtoken to expose the app publicly. Get one at https://dashboard.ngrok.com
# Either authtoken variable name works; NGROK_AUTH_TOKEN is preferred.
# Do not place API keys (ak_...) in NGROK_AUTH_TOKEN.
NGROK_AUTH_TOKEN=your_ngrok_authtoken_here
NGROK_AUTHTOKEN=
# Optional: ngrok API key for management API usage (not tunnel auth)
NGROK_API_KEY=
# Optional: static domain from your ngrok dashboard (e.g. abc123.ngrok-free.app)
NGROK_DOMAIN=
